#!/bin/bash

PROJECTS_DIR="$HOME/projects"

# Handle Argument
if [ -n "${1:-}" ]; then
  TARGET_DIR="$PROJECTS_DIR/$1"
  if [ ! -d "$TARGET_DIR" ]; then
    echo "Error - '$1' is not a valid project"
    exit 1
  fi
  SESSION_NAME="$1"

# Handle Logic if no Argument is provided
else
  CURRENT_DIR=$(pwd)

  # use the project folder as session - if we are in it
  if [[ "$CURRENT_DIR" == "$PROJECTS_DIR"/* ]]; then
    SESSION_NAME=$(echo "$CURRENT_DIR" | sed "s|^$PROJECTS_DIR/||" | cut -d'/' -f1)
  else
    # Open fzf to pick a project.
    SESSION_NAME=$(find "$PROJECTS_DIR" -maxdepth 1 -mindepth 1 -type d -printf '%f\n' | fzf --height 40% --reverse --header="Select a Project")

    if [ -z "$SESSION_NAME" ]; then
      echo "No project selected."
      exit 0
    fi
  fi
  TARGET_DIR="$PROJECTS_DIR/$SESSION_NAME"
fi

cd "$TARGET_DIR" || exit 1

# remove ANSI-Escape-sequences
CLEAN_SESSIONS=$(zellij list-sessions | sed 's/\x1b\[[0-9;]*m//g')

# Get the line for this session (first field exact match, safe against regex chars)
SESSION_LINE=$(printf '%s\n' "$CLEAN_SESSIONS" | awk -v s="$SESSION_NAME" '$1 == s {print; exit}')

if [ -n "$SESSION_LINE" ]; then
  # Check if session is dead/exited
  if printf '%s\n' "$SESSION_LINE" | grep -Fq "[Exited]"; then
    zellij delete-session "$SESSION_NAME"
  else
    exec zellij attach "$SESSION_NAME"
  fi
fi

# start new session
exec zellij --session "$SESSION_NAME" --layout project-tabs
